{
    "manifest_version": 3,
    "name": "Jupiter Catalog",
    "version": "1.0.0",
    "description": "Manage catalog items",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "http://localhost:3001/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "jupiter.svg"
        }
    }
}